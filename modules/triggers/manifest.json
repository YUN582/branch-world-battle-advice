{
  "id": "triggers",
  "name": "트리거 자동화",
  "version": "1.0.0",
  "type": "data",
  "description": "기본 트리거 프리셋 — 피해, 스탯 설정, 판정, 장면 전환 등 코코포리아 범용 자동화",
  "author": "CE",
  "minCoreVersion": "1.2.0",
  "tags": ["triggers", "automation"],

  "triggers": [
    {
      "id": "_builtin_damage",
      "name": "피해",
      "enabled": false,
      "pattern": "《피해》| {대상} | {스탯} | {수치}",
      "source": "input",
      "conditions": { "states": [] },
      "actions": [
        { "type": "stat", "target": "{대상}", "stat": "{스탯}", "op": "-", "value": "{수치}" },
        { "type": "message", "template": "💥 {대상}의 {스탯}에 -{수치} 피해!" }
      ],
      "delay": 300,
      "priority": 0
    },
    {
      "id": "_builtin_set_stat",
      "name": "스탯 설정",
      "enabled": false,
      "pattern": "《설정》| {대상} | {스탯} | {수치}",
      "source": "input",
      "conditions": { "states": [] },
      "actions": [
        { "type": "stat", "target": "{대상}", "stat": "{스탯}", "op": "=", "value": "{수치}" }
      ],
      "delay": 300,
      "priority": 0
    },
    {
      "id": "_builtin_dice_crit",
      "name": "대성공 알림",
      "enabled": false,
      "pattern": "",
      "source": "message",
      "conditions": { "states": [] },
      "actions": [
        { "type": "condition_dice", "op": "==", "value": "20", "inGroup": false },
        { "type": "message", "template": "🎯 대성공! (주사위 결과: {주사위})", "inGroup": true }
      ],
      "delay": 300,
      "priority": 0
    },
    {
      "id": "_builtin_dice_fumble",
      "name": "대실패 알림",
      "enabled": false,
      "pattern": "",
      "source": "message",
      "conditions": { "states": [] },
      "actions": [
        { "type": "condition_dice", "op": "==", "value": "1", "inGroup": false },
        { "type": "message", "template": "💀 대실패... (주사위 결과: {주사위})", "inGroup": true }
      ],
      "delay": 300,
      "priority": 0
    },
    {
      "id": "_builtin_scene_change",
      "name": "장면 전환",
      "enabled": false,
      "pattern": "《장면》| {장면이름}",
      "source": "input",
      "conditions": { "states": [] },
      "actions": [
        { "type": "message", "template": "🎬 장면 전환: {장면이름}" },
        { "type": "load_scene", "sceneName": "{장면이름}", "applyOption": "all" }
      ],
      "delay": 300,
      "priority": 0
    },
    {
      "id": "_builtin_dice_check",
      "name": "판정",
      "enabled": false,
      "pattern": "《판정》",
      "source": "input",
      "conditions": { "states": [] },
      "actions": [
        { "type": "dice", "command": "1d20" },
        { "type": "condition_dice", "op": ">=", "value": "15", "inGroup": false },
        { "type": "message", "template": "✅ {내캐릭터} 판정 성공! (🎲 {주사위})", "inGroup": true },
        { "type": "condition_dice", "op": "<", "value": "15", "inGroup": false },
        { "type": "message", "template": "❌ {내캐릭터} 판정 실패... (🎲 {주사위})", "inGroup": true }
      ],
      "delay": 300,
      "priority": 0
    }
  ]
}
