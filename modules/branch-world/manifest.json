          "desc": "다음 차례까지 [이동], [돌진], [도약] 불가하고, [속박] 제거."
        },
        "충격💥": {
          "type": "cc",
          "emoji": "💥",
          "name": "충격",
          "stacking": true,
          "desc": "다음 차례까지 -[충격]×2의 수정치를 받고, [충격] 제거."
        },
        "기절🌀": {
          "type": "cc",
          "emoji": "🌀",
          "name": "기절",
          "desc": "다음 차례까지 [대응]과 [보조 행동]과 [주 행동] 불가하고, [기절] 제거."
        },
        "둔화⌛": {
          "type": "cc",
          "emoji": "⌛",
          "name": "둔화",
          "desc": "다음 차례까지 [이동거리]/2, [둔화] 제거."
        },
        "방황💫": {
          "type": "cc",
          "emoji": "💫",
          "name": "방황",
          "desc": "다음 차례까지 [보조 행동] 불가하고, [방황] 제거."
        },
        "붕괴⛓️‍💥": {
          "type": "cc",
          "emoji": "⛓️‍💥",
          "name": "붕괴",
          "desc": "다음 차례까지 [장갑]/2 하고, [붕괴] 제거."
        },
        "출혈🩸": {
          "type": "onHit",
          "emoji": "🩸",
          "name": "출혈",
          "desc": "피해 받을 시, [출혈] 만큼 추가 피해를 받고 [출혈] -1."
        },
        "화상🔥": {
          "type": "turnDecay",
          "emoji": "🔥",
          "name": "화상",
          "desc": "매 차례마다 [화상] 만큼 피해를 받고 [화상] -1.\n[화상]이 있는 동안, 가하는 [피해]÷2."
        },
        "중독🤢": {
          "type": "turnDecay",
          "emoji": "🤢",
          "name": "중독",
          "desc": "매 차례마다 [중독]×2 만큼 장갑 무시 피해를 받고 [중독] -1."
        },
        "동상❄️": {
          "type": "turnDecay",
          "emoji": "❄️",
          "name": "동상",
          "desc": "매 차례마다 [동상] 만큼 피해를 받고 [동상] -1.\n[동상]이 있는 동안, [행동 순서]와 [이동 거리] -[동상]."
        },
        "감전⚡": {
          "type": "turnDecay",
          "emoji": "⚡",
          "name": "감전",
          "desc": "매 차례마다 [감전] -1.\n[감전]이 5가 되면, [감전]×4 만큼의 [장갑 무시 피해]를 주고 [감전] 제거."
        }
      }
    }
